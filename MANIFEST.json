{
  "name": "agent-learning-compounder",
  "version": "2026.05.27+review7-plus2.2",
  "schema_version": 1,
  "created_date": "2026-05-27",
  "description": "Distills repo facts, session telemetry, and skill-health signals into durable, evidence-backed agent memory. Installs as a Codex skill, a Claude Code plugin, or both.",
  "requirements": {
    "python": ">=3.10",
    "shell": "POSIX sh"
  },
  "install": {
    "default_root": "${AGENTS_HOME:-$HOME/.agents}/skills",
    "claude_root": "${CLAUDE_HOME:-$HOME/.claude}/skills",
    "codex_home_root": "${CODEX_HOME:-$HOME/.codex}/skills",
    "custom_root_flag": "--target DIR"
  },
  "entrypoints": [
    "scripts/init_learning_system.py",
    "scripts/install_runtime_hooks.py",
    "scripts/refresh_learning_state.py",
    "scripts/collect_hook_event.py",
    "scripts/replay_hook_events.py",
    "scripts/queue_dedup.py",
    "scripts/evaluate_gate_effectiveness.py",
    "scripts/propose_domain_rules.py",
    "scripts/causal_probe.py",
    "scripts/gates_promote.py",
    "scripts/gates_inherit.py",
    "scripts/serve_dashboard.py",
    "scripts/alc_init.py",
    "scripts/ce_playbook.py"
  ],
  "optional_extras": {
    "mcp": "alc_mcp/server.py — install: pip install mcp",
    "dashboard": "bin/serve_dashboard — install: pip install fastapi jinja2 uvicorn httpx",
    "embedding": "bin/queue_dedup --backend embed — install: pip install sentence-transformers"
  },
  "required_docs": [
    "README.md",
    "CHANGES.md",
    "agent-learning-compounder/skills/alc-core/SKILL.md",
    "agent-learning-compounder/skills/alc-core/references/agent-quickstart.md",
    "agent-learning-compounder/skills/alc-core/references/architecture.md",
    "agent-learning-compounder/skills/alc-core/references/event-schema-evolution.md",
    "agent-learning-compounder/skills/alc-core/references/queue-dedup.md",
    "agent-learning-compounder/skills/alc-core/references/gate-effectiveness.md",
    "agent-learning-compounder/skills/alc-core/references/domain-rules-learning.md",
    "agent-learning-compounder/skills/alc-core/references/cross-repo-gates.md"
  ],
  "excluded_from_package": [
    "__pycache__",
    "*.pyc",
    ".agent-learning.json",
    "review-patches.diff",
    "runtime state"
  ]
}

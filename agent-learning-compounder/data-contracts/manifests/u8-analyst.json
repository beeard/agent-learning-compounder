{
  "artifacts": [
    {
      "id": "patterns",
      "path_template": "patterns.json",
      "producer": "analyst_patterns",
      "consumers": ["dashboard", "analytics"],
      "surface_in_dashboard": true,
      "format": "json",
      "lifecycle": {
        "create": "analyst_patterns",
        "read": "all",
        "update": "analyst_patterns",
        "delete_or_retention": "manual_cleanup",
        "owner": "repo_state",
        "states": ["repo"],
        "max_age": "180d",
        "max_count": 5,
        "cleanup_command": ""
      },
      "max_size": 1048576
    },

{
  "artifacts": [
    {
      "id": "patch_applied-event",
      "path_template": "events.sqlite",
      "producer": "alc_apply",
      "consumers": ["alc_apply", "alc_query", "dashboard"],
      "surface_in_dashboard": true,
      "format": "sqlite-event",
      "lifecycle": {
        "create": "alc_apply",
        "read": "all",

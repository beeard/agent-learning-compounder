{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${ALC_PLUGIN_ROOT}/hooks/session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${ALC_PLUGIN_ROOT}/hooks/refresh_dashboard.py"
          }
        ]
      }
    ]
  }
}

#!/usr/bin/env bash
set -u
state_root="${AGENT_LEARNING_STATE_DIR:-$PWD/.agent-learning}"
: "${ALC_PLUGIN_ROOT:?ALC_PLUGIN_ROOT is required}"
cat "$state_root"/repos/*/reports/latest-approved-gates.md 2>/dev/null || true
cat "$state_root"/repos/*/reports/latest-skill-context.md "$ALC_PLUGIN_ROOT"/skills/alc-core/SKILL.md 2>/dev/null || true

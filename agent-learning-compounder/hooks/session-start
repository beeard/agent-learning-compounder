#!/usr/bin/env bash
set -u
state_root="${AGENT_LEARNING_STATE_DIR:-$PWD/.agent-learning}"
plugin_root="${CLAUDE_PLUGIN_ROOT:-${ALC_PLUGIN_ROOT:-}}"
if [ -z "$plugin_root" ]; then
  echo "session-start: CLAUDE_PLUGIN_ROOT or ALC_PLUGIN_ROOT must be set" >&2
  exit 1
fi
cat "$state_root"/repos/*/reports/latest-approved-gates.md 2>/dev/null || true
cat "$state_root"/repos/*/reports/latest-session-context.md 2>/dev/null || true
cat "$state_root"/repos/*/reports/latest-skill-context.md "$plugin_root"/skills/alc-core/SKILL.md 2>/dev/null || true
